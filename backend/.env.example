APP_NAME=AI Dropout Predictor
APP_ENV=development
DEBUG=true

# Generate a strong value for production: python -c "import secrets;print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-please-this-is-only-for-local-dev
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# SQLite by default. Switch to Postgres by setting:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db
DATABASE_URL=sqlite:///./app.db

# Comma-separated allow-list. Use "*" only in trusted dev environments.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760

# ML artifacts + default dataset
ML_ARTIFACT_DIR=../ml/artifacts
ML_DEFAULT_DATASET=../datasets/sample_students.csv

# Local LLM (Ollama). Leave OLLAMA_BASE_URL blank to disable LLM completely.
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=phi3
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=512

# Rate limits
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_CHAT=30/minute

# Seed defaults (override before first run if you like)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123
