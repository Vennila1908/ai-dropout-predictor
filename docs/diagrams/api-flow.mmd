  AUTHM --> R{"Endpoint group"}
  R --> A1["/auth"]
  R --> U1["/users"]
  R --> S1["/students"]
  R --> UP["/uploads"]
  R --> P1["/predictions"]
  R --> ML1["/ml"]
  R --> RC["/recommendations"]
  R --> CO["/counseling"]
  R --> AN["/analytics"]
  R --> RP["/reports"]
  R --> CH["/chat"]
  R --> H["/health"]

  S1 --> SVC1["StudentService"]
  UP --> SVC2["UploadService"]
  P1 --> SVC3["PredictionService"]
  ML1 --> SVC4["MLService"]
  RC --> SVC5["RecommendationService"]
  CH --> SVC6["ChatService"]

  SVC1 --> REPO[("Repositories")]
  SVC2 --> REPO
  SVC3 --> REPO
